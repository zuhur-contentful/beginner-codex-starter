# ─── AI ──────────────────────────────────────────────────────────────────────
# For your app to call AI, use OpenRouter (free tier, no credit card needed).
# Sign up at https://openrouter.ai and create a key.
# Only needed if your app makes AI calls -- not needed to use Codex itself.
OPENROUTER_API_KEY=

# Once you outgrow the free tier, you can switch to a paid OpenAI key instead:
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# ─── App security ────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ─── Database (optional — only needed if using Supabase instead of SQLite) ───
# Get these from: Supabase > Project Settings > API
SUPABASE_URL=https://<your-ref>.supabase.co
SUPABASE_ANON_KEY=

# ─── GitHub MCP (optional — lets Codex help with your GitHub issues/PRs) ────
# Get this from: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# ─── App config ──────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=true
ENVIRONMENT=development
